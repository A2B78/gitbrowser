# =============================================
# GitBrowser - Configuration
# Copie ce fichier en .env et remplis les valeurs
# =============================================

# Server
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost

# JWT Secret (génère avec: openssl rand -base64 64)
JWT_SECRET=change_this_to_a_random_secret_at_least_64_chars_long

# GitHub OAuth App
# Créer sur https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost/api/auth/github/callback