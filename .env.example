# =============================================
# GitBrowser - Configuration
# Copie ce fichier en .env et remplis les valeurs
# =============================================

# Server
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost

# JWT Secret (génère avec: openssl rand -base64 64)
JWT_SECRET=change_this_to_a_random_secret_at_least_64_chars_long

# GitHub OAuth App
# Créer sur https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# AI Provider Configuration (optional)
# Providers disponibles: openai, anthropic, ollama, openai_compatible
AI_PROVIDER=openai
AI_API_KEY=your_ai_api_key
AI_MODEL=gpt-4

# Pour Anthropic
# AI_PROVIDER=anthropic
# AI_API_KEY=your_anthropic_api_key
# AI_MODEL=claude-3-sonnet-20240229

# Pour Ollama (local)
# AI_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# AI_MODEL=llama2

# Pour API compatible OpenAI (LocalAI, vLLM, etc.)
# AI_PROVIDER=openai_compatible
# AI_API_URL=http://localhost:8080/v1
# AI_MODEL=default
